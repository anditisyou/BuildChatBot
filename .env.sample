# Copy this file to `.env` and fill values. Do NOT commit `.env` to source control.
# Example values (replace with your production credentials on Render):
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=dsl_chatbot
PORT=5000
NODE_ENV=production
JWT_SECRET=replace_with_a_secure_random_string
REDIS_URL=redis://localhost:6379  # Optional

# Notes:
# - On Render, set these values in the service's Environment tab (do not commit secrets).
# - Keep `.env` listed in .gitignore to avoid accidental commits.
